// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Prisma Setup
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User & Preferences
model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?

  carts        Cart[]
  preferences  UserPreference?
  storePrefs   StorePreference[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique

  optimizeFor     String   @default("cost")

  monthlyBudget   Decimal? @db.Numeric(10, 2)
  perTripBudget   Decimal? @db.Numeric(10, 2)

  user            User     @relation(fields: [userId], references: [id])
}

model StorePreference {
  id         String  @id @default(cuid())
  userId     String
  storeId    String
  isFavorite Boolean @default(false)
  isExcluded Boolean @default(false)

  user       User    @relation(fields: [userId], references: [id])
  store      Store   @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
}

// Stores & Items
model Store {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  address     String?
  city        String?
  state       String?
  zip         String?
  latitude    Float?
  longitude   Float?

  storeItems  StoreItem[]
  preferences StorePreference[]
  carts       Cart[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Item {
  id                String              @id @default(cuid())
  name              String
  normalizedName    String
  category          String?
  defaultUnit       String?

  storeItems        StoreItem[]
  recipeIngredients RecipeIngredient[]

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model StoreItem {
  id            String   @id @default(cuid())
  storeId       String
  itemId        String

  price         Decimal  @db.Numeric(10, 2)
  currency      String   @default("USD")
  lastUpdated   DateTime @default(now())
  isEstimated   Boolean  @default(false)
  userConfirmed Boolean  @default(false)

  store         Store    @relation(fields: [storeId], references: [id])
  item          Item     @relation(fields: [itemId], references: [id])

  @@unique([storeId, itemId])
}

// Carts
enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ARCHIVED
}

model Cart {
  id            String        @id @default(cuid())
  ownerId       String
  status        CartStatus    @default(ACTIVE)

  owner         User          @relation(fields: [ownerId], references: [id])
  items         CartItem[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  itemId      String

  quantity    Float
  unit        String?

  cart        Cart     @relation(fields: [cartId], references: [id])
  item        Item     @relation(fields: [itemId], references: [id])

  @@unique([cartId, itemId, unit])
}

// Recipes
model Recipe {
  id            String             @id @default(cuid())
  externalId    String?
  title         String
  source        String?
  thumbnailUrl  String?
  instructions  String?

  ingredients   RecipeIngredient[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([externalId])
}

model RecipeIngredient {
  id          String   @id @default(cuid())
  recipeId    String
  itemId      String?
  rawName     String
  quantity    Float?
  unit        String?

  recipe      Recipe   @relation(fields: [recipeId], references: [id])
  item        Item?    @relation(fields: [itemId], references: [id])
}
